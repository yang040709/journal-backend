    "@types/koa-logger": "^3.1.5",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^20.19.25",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "nodemon": "^3.1.11",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@koa/router": "^14.0.0",
