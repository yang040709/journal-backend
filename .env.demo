PORT=3000
MONGO_URI=mongodb://localhost:27017/journal2
JWT_SECRET=xxxxx
REDIS_URL=redis://localhost:6379
WX_APPID=wxde0c030342157ec7
WX_SECRET=xxx
NODE_ENV=development
# MONGO_URI=mongodb://host.docker.internal:27017/schedule-management
# REDIS_URL=redis://host.docker.internal:6379

# 敏感词加密密钥（32字节）
SENSITIVE_WORDS_KEY=your-32-byte-encryption-key-here-123456

# 日志配置 - 针对30用户优化（本地开发环境）
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=5m      # 每个日志文件最大5MB
LOG_MAX_FILES=7d     # 保留7天的日志文件

# 示例占位，勿填真实 AKID；真实值放 .env（且勿提交）
COS_SECRET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COS_SECRET_KEY=xxxx
COS_BUCKET=user-image-1379860077
COS_REGION=ap-guangzhou
COS_PUBLIC_DOMAIN=https://user-img.leyang.asia 
COS_UPLOAD_DIR=journal
COS_STS_DURATION_SECONDS=1800
COS_MAX_FILE_SIZE_MB=10
UPLOAD_DAILY_BASE_LIMIT=15


DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_DAILY_BASE_LIMIT=5


# 后台管理（Admin Web）：须与 JWT_SECRET 不同，用于签发管理员 Token
ADMIN_JWT_SECRET=xxxx
# 可选，默认 7d
# ADMIN_JWT_EXPIRES_IN=7d
# 首次启动且无超级管理员时，用以下账号创建一条 role=super 的记录（密码 bcrypt 存储）
# 开发可复制为 admin / 123456；生产务必改为强密码
ADMIN_BOOTSTRAP_USERNAME=xxx
ADMIN_BOOTSTRAP_PASSWORD=xxx