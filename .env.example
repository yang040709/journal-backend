# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB配置
MONGO_URI=mongodb://127.0.0.1:27017/journal

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 后台管理（Admin Web）：须与 JWT_SECRET 不同，用于签发管理员 Token
ADMIN_JWT_SECRET=your-admin-jwt-secret-change-this
# 可选，默认 7d
# ADMIN_JWT_EXPIRES_IN=7d
# 首次启动且无超级管理员时，用以下账号创建一条 role=super 的记录（密码 bcrypt 存储）
# 开发可复制为 admin / 123456；生产务必改为强密码
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=123456
# Admin 前端地址（CORS，生产必填；多个用英文逗号分隔）
# 开发环境若不配置，则自动允许 http(s)://localhost 与 127.0.0.1 任意端口
# ADMIN_CORS_ORIGIN=http://localhost:5173
# ADMIN_CORS_ORIGIN=https://admin.example.com,https://admin-staging.example.com

# 微信小程序风控（文本 + 图片）
# WX_APPID=wx1234567890abcdef
# WX_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 兼容别名：如果你的环境里用的是 WX_SE，也可以（等同 WX_SECRET）
# WX_SE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 分享风控任务扫描间隔（毫秒，默认 3000）
# SHARE_SECURITY_WORKER_INTERVAL_MS=3000
# 分享风控任务最大重试次数（默认 3）
# SHARE_SECURITY_MAX_RETRY=3

# 管理端可配置的系统封面 URL 最大条数（默认 120，上限 500）
# MAX_SYSTEM_COVERS=120

# 敏感词加密密钥（32字节）
SENSITIVE_WORDS_KEY=your-32-byte-encryption-key-here-123456

# 日志配置 - 针对30用户优化
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=5m      # 每个日志文件最大5MB
LOG_MAX_FILES=7d     # 保留7天的日志文件

# 可选：Redis配置（用于缓存）
# REDIS_URL=redis://localhost:6379
# 缓存总开关（默认 true）
# CACHE_ENABLED=true
# 统计类轻量接口缓存 TTL（秒，默认 45）
# CACHE_STATS_USER_TTL_SECONDS=45
# 统计类重计算接口缓存 TTL（秒，默认 120）
# CACHE_STATS_HEAVY_TTL_SECONDS=120
# 管理端运营报表缓存 TTL（秒，默认 240）
# CACHE_ADMIN_OPERATIONS_REPORT_TTL_SECONDS=240

# AI 写手帐（DeepSeek，OpenAI 兼容接口）
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# AI 每日基础次数：已迁移为后台可配（SystemConfig: quota_base_limits / /admin/quota/base-limits）
# 这里不再作为运行时配置项；若你在本地想重置默认值，请清空对应 SystemConfig 文档或修改后台配置。
# （已废弃）原 AI 额度独立广告接口 env；激励视频改走积分，次数/单次积分在管理端「积分规则」或库内 points_rules 配置
# AI_AD_REWARD_VALUE=5
# AI_AD_REWARD_DAILY_LIMIT=6

# 可选：腾讯云 COS 上传凭证签发配置（图片直传 COS）
# COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxx
# COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# COS_BUCKET=journal-1250000000
# COS_REGION=ap-guangzhou
# COS_PUBLIC_DOMAIN=https://cdn.example.com
# COS_UPLOAD_DIR=journal
# COS_STS_DURATION_SECONDS=1800
# COS_MAX_FILE_SIZE_MB=2
# ADMIN_GALLERY_MAX_FILE_SIZE_MB=5

# 上传每日基础额度：已迁移为后台可配（SystemConfig: quota_base_limits / /admin/quota/base-limits）
# 这里不再作为运行时配置项；若你在本地想重置默认值，请清空对应 SystemConfig 文档或修改后台配置。
# UPLOAD_QUOTA_TIMEZONE=Asia/Shanghai
# （已废弃）原上传额度独立广告接口 env；同上，请用积分体系配置
# UPLOAD_AD_REWARD_VALUE=3
# UPLOAD_AD_REWARD_DAILY_LIMIT=6
